<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

  <display-name>Haining Biomed Web Application</display-name>

  <!--
    DispatchServlet: 项目原有的前端控制器
    注意：原有路由（/, /matchingIndex, /samples, /drugs 等）均由 IndexController/
    KnowledgeBaseController/MatchingController 注册到 DispatchServlet 内部。
    DispatchServlet 本身使用 getPathInfo() 来路由，所以它需要映射在 /* 或某个前缀下。
    原项目在 web.xml 中没有显式声明 DispatchServlet，说明它是通过某种隐式方式加载的，
    或者 servlet 路径配置在别处。保留原有 welcome-file 配置即可。
  -->

  <!--
    CounterServlet 通过 @WebServlet("/counter") 注解自动注册。
    Servlet 3.1 容器（Tomcat 8+）会扫描注解，无需在此重复声明。
    若需要兼容旧版 Tomcat，可取消下方注释：

    <servlet>
      <servlet-name>CounterServlet</servlet-name>
      <servlet-class>cn.edu.zju.servlet.CounterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
      <servlet-name>CounterServlet</servlet-name>
      <url-pattern>/counter</url-pattern>
    </servlet-mapping>
  -->

  <welcome-file-list>
    <welcome-file>index</welcome-file>
  </welcome-file-list>

</web-app>
